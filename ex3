import java.util.Scanner;
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        //acumulador.

        int contador = 1;
        int acumulador = 0;

        while (contador <=100){
            acumulador = acumulador + contador;
            System.out.println(contador+"");
            contador++;;
        }
        System.out.println("A soma é:"+acumulador);
        sc.close();
    }
}
