import java.util.Scanner;
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        double nota;

        do{
            System.out.println("==========Digite uma nota de 0 a 10==========");
            nota = sc.nextDouble();
        }
        while (nota < 0 || nota < 10){
            System.out.println("Nota correta");
        }
        sc.close();
    }
}
